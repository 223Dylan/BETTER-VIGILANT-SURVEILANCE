# =============================================================================
# SHOPLIFTING DETECTION SYSTEM - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and update the values for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/shoplifting_detection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shoplifting_detection
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Database pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# SSL settings (for production)
DB_SSL_MODE=prefer
DB_SSL_CERT_PATH=/path/to/client-cert.pem
DB_SSL_KEY_PATH=/path/to/client-key.pem
DB_SSL_ROOT_CERT_PATH=/path/to/ca-cert.pem

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate strong secrets for production: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-at-least-32-characters-long-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# =============================================================================
# ENCRYPTION SETTINGS
# =============================================================================
ENCRYPTION_PASSWORD=your-encryption-password-change-in-production
ENCRYPTION_SALT=your-encryption-salt-change-in-production

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=4
API_DEBUG=true

# CORS settings
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_SECOND=10

# =============================================================================
# SECURITY HEADERS
# =============================================================================
FORCE_HTTPS=false
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# =============================================================================
# CELERY CONFIGURATION (Message Queue)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKERS=4

# =============================================================================
# ELK STACK CONFIGURATION
# =============================================================================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=shoplifting-detection
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5000
KIBANA_URL=http://localhost:5601

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================
MODEL_PATH=models/lrcn_160S_90_90Q.h5
MODEL_SEQUENCE_LENGTH=160
MODEL_FRAME_SIZE=90
USE_GPU=false

# Detection thresholds
DETECTION_THRESHOLD_LOW=0.3
DETECTION_THRESHOLD_MEDIUM=0.6
DETECTION_THRESHOLD_HIGH=0.8

# =============================================================================
# CAMERA SETTINGS
# =============================================================================
DEFAULT_CAMERA_FPS=15
DEFAULT_CAMERA_RESOLUTION_WIDTH=640
DEFAULT_CAMERA_RESOLUTION_HEIGHT=480
CAMERA_TIMEOUT=5.0

# =============================================================================
# FILE STORAGE
# =============================================================================
UPLOAD_DIRECTORY=uploads
TEMP_FRAMES_DIRECTORY=temp_frames
OUTPUT_DIRECTORY=output
MAX_UPLOAD_SIZE=100

# Video file settings
ALLOWED_VIDEO_EXTENSIONS=mp4,avi,mov,mkv
VIDEO_PROCESSING_TIMEOUT=300

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/main.log
LOG_MAX_SIZE=10
LOG_BACKUP_COUNT=5

# Enable/disable specific log categories
LOG_DETECTION_EVENTS=true
LOG_API_REQUESTS=true
LOG_CAMERA_EVENTS=true
LOG_SYSTEM_METRICS=true

# =============================================================================
# MONITORING AND ALERTING
# =============================================================================
METRICS_COLLECTION_INTERVAL=60
SYSTEM_MONITORING_ENABLED=true
ALERT_COOLDOWN_PERIOD=60
MAX_ALERTS_PER_MINUTE=5

# =============================================================================
# EMAIL NOTIFICATIONS (Optional)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=admin@yourcompany.com

# =============================================================================
# WEBHOOK NOTIFICATIONS (Optional)
# =============================================================================
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
WEBHOOK_TIMEOUT=10

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Set to 'development', 'staging', or 'production'
ENVIRONMENT=development

# Enable/disable features for development
ENABLE_API_DOCS=true
ENABLE_CORS=true
ENABLE_DEBUG_TOOLBAR=false
RELOAD_ON_CHANGE=true

# =============================================================================
# DOCKER SETTINGS (when using Docker)
# =============================================================================
DOCKER_NETWORK=shoplifting_detection_network
POSTGRES_CONTAINER_NAME=shoplifting_postgres
REDIS_CONTAINER_NAME=shoplifting_redis
ELASTICSEARCH_CONTAINER_NAME=shoplifting_elasticsearch

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
FRONTEND_URL=http://localhost:3000
WEBSOCKET_URL=ws://localhost:8001

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_DIRECTORY=/backups
BACKUP_RETENTION_DAYS=30
AUTO_BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
MAX_FRAME_BUFFER_SIZE=50
FRAME_PROCESSING_THREADS=4
MAX_CONCURRENT_CAMERAS=10
MEMORY_LIMIT_MB=2048 